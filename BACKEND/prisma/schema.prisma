// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Model untuk User (Admin)
enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nama      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

// 2. Model untuk Menu Makanan
model Menu {
  id          String      @id @default(uuid())
  nama        String
  harga       Float
  deskripsi   String?
  category    String
  imageURL    String?     // URL or file path of the menu image
  isAvailable Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

// 3. Model untuk Induk Pesanan
enum OrderStatus {
  PENDING
  PAID
  NOT_PAID
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerEmail String
  customerPhone String
  paymentMethod String
  receiptImage  String?     // Path to uploaded receipt image
  status        OrderStatus @default(PENDING)
  totalPrice    Float
  createdAt     DateTime    @default(now())
  orderItems    OrderItem[]
}

// 4. Model untuk Detail Item yang Dipesan (1 order bisa banyak menu)
model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String
  menu      Menu   @relation(fields: [menuId], references: [id])
  kuantitas Int
  harga     Float  // Menyimpan harga saat dibeli (jika di masa depan harga menu berubah)
}

