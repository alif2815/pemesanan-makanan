
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. Model untuk User (Admin)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nama      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

// 2. Model untuk Menu Makanan
model Menu {
  id          String      @id @default(uuid())
  nama        String
  harga       Float
  deskripsi   String?
  category    String
  imageURL    String?     // URL or file path of the menu image
  isAvailable Boolean     @default(true)
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

// 3. Model untuk Induk Pesanan
model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerEmail String
  customerPhone String
  paymentMethod String
  receiptImage  String?     // Path to uploaded receipt image
  status        String      @default("PENDING")
  totalPrice    Float
  createdAt     DateTime    @default(now())
  orderItems    OrderItem[]
  transaction   Transaction?
}

// 4. Model untuk Detail Item yang Dipesan (1 order bisa banyak menu)
model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String
  menu      Menu   @relation(fields: [menuId], references: [id])
  kuantitas Int
  harga     Float  // Menyimpan harga saat dibeli (jika di masa depan harga menu berubah)
}

// 5. Model untuk Reservasi Meja
model Reservation {
  id             String    @id @default(uuid())
  name           String
  email          String?
  phone          String
  date           DateTime
  time           String
  numberOfPeople Int
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
}

// 6. Model untuk Transaksi
model Transaction {
  id            String    @id @default(uuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  paymentMethod String
  status        String    @default("PENDING")
  paymentDate   DateTime?
  createdAt     DateTime  @default(now())
}
